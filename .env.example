# Copy to .env for local runs. Never commit the real .env (it's gitignored).

# Directory of webhook-format JSON files to dedupe. Defaults to the
# bundled sample feeds shipped with the package.
ALERT_DEDUPE_INPUT_DIR=

# A group (same underlying issue, seen this many times or more) is
# reported as "escalated" instead of "success".
ALERT_DEDUPE_ESCALATE_THRESHOLD=5

# Optional: AiOps Enabler reporting. Leave both blank to run fully offline
# with no phone-home. Set both to enable signed task-event reporting.
ALERT_DEDUPE_AGENT_KEY_ID=
ALERT_DEDUPE_AGENT_SECRET=
ALERT_DEDUPE_BASE_URL=https://api.aiopsenabler.com
